{
  "server": { "host": "0.0.0.0", "port": 8000 },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": null,
    "keyPrefix": "pyclaw:",
    "transcriptRetentionDays": 7
  },
  "storage": { "session_backend": "memory", "memory_backend": "sqlite", "lock_backend": "file" },
  "memory": {
    "base_dir": "~/.pyclaw/memory",
    "l1_max_entries": 30,
    "l1_max_chars": 3000,
    "l1_ttl_seconds": 2592000
  },
  "embedding": {
    "model": "",
    "apiKey": "",
    "baseURL": "",
    "dimensions": 4096
  },
  "agent": {
    "default_model": "gpt-4o",
    "providers": { "openai": { "apiKey": null, "baseURL": null } },
    "max_iterations": 50,
    "context_window": 128000,
    "timeouts": {
      "run_seconds": 300.0,
      "idle_seconds": 60.0,
      "tool_seconds": 120.0,
      "compaction_seconds": 900.0
    },
    "retry": {
      "planning_only_limit": 1,
      "reasoning_only_limit": 2,
      "empty_response_limit": 1,
      "unknown_tool_threshold": 3
    },
    "compaction": {
      "model": null,
      "threshold": 0.8,
      "keep_recent_tokens": 20000,
      "timeout_seconds": 900.0,
      "truncate_after_compaction": false
    },
    "tools": { "max_output_chars": 25000 }
  },
  "workspaces": { "default": "~/.pyclaw/workspaces", "backend": "file", "bootstrapFiles": ["AGENTS.md"] },
  "skills": {
    "workspaceSkillsDir": "skills",
    "projectAgentsSkillsDir": ".agents/skills",
    "managedSkillsDir": "~/.openclaw/skills",
    "personalAgentsSkillsDir": "~/.agents/skills",
    "bundledSkillsDir": null,
    "clawhubBaseUrl": "https://clawhub.ai",
    "maxSkillsInPrompt": 150,
    "maxSkillsPromptChars": 18000,
    "maxSkillFileBytes": 256000,
    "maxCandidatesPerRoot": 300,
    "maxSkillsLoadedPerSource": 200
  },
  "channels": {
    "feishu": {
      "enabled": false,
      "appId": "",
      "appSecret": "",
      "sessionScope": "chat",
      "groupContext": "recent",
      "groupContextSize": 20,
      "idleMinutes": 0
    },
    "web": {
      "enabled": false,
      "jwtSecret": "change-me-in-production",
      "adminToken": "admin-secret",
      "heartbeatInterval": 30,
      "pongTimeout": 10,
      "maxConnectionsPerUser": 3,
      "bufferTtlSeconds": 300,
      "bufferMaxEntries": 1000,
      "toolsRequiringApproval": ["bash", "write"],
      "allowedTools": ["read"],
      "corsOrigins": ["http://localhost:5173"],
      "users": [{"id": "admin", "password": "changeme"}]
    }
  }
}
