# PyClaw production environment variables.
# Copy to deploy/.env and fill in real values before running docker compose.

# ── Web channel auth (REQUIRED for web channel) ─────────────────────────
# JWT signing secret. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
PYCLAW_WEB_JWT_SECRET=replace-me-with-64-random-bytes

# Admin token for /api/admin/* endpoints (cluster status, etc.)
PYCLAW_WEB_ADMIN_TOKEN=replace-me-with-32-random-bytes

# ── Public ingress port ─────────────────────────────────────────────────
# Defaults to 80. Override if 80 is taken on the host.
PYCLAW_NGINX_PORT=80

# ── Optional: redis password ────────────────────────────────────────────
# Uncomment + set if Redis is exposed on a shared network.
# PYCLAW_REDIS_PASSWORD=

# ── Optional: per-provider API keys ────────────────────────────────────
# These map to settings.agent.providers.<name>.apiKey at runtime via the
# PYCLAW_AGENT_PROVIDERS_<NAME>_API_KEY env override mechanism (pydantic).
# In practice it is simpler to put keys in configs/pyclaw.json directly
# (mounted read-only) than to env-override the nested structure.
